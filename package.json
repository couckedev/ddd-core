{
  "name": "@couckedev/ddd-core",
  "version": "2.0.0",
  "description": "Core DDD classes, interfaces, etc",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@vitest/coverage-v8": "^3.0.9",
    "eslint": "^9.22.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/couckedev/ddd-core.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}